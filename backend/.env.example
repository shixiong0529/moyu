DATABASE_URL=sqlite:///./biscord.db
SECRET_KEY=please-replace-with-a-random-string-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram Bot — 从 @BotFather 获取
# 留空时通知功能静默禁用，不影响其他功能
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=please-replace-with-a-random-string
# 可选：生产环境填写服务器域名（用于自动注册 Webhook）
# 本地开发可使用 ngrok: https://ngrok.com
APP_BASE_URL=

# 可选：Telegram 代理（国内服务器无法直连 api.telegram.org 时配置）
# 支持 SOCKS5 和 HTTP 代理，例如：
#   TELEGRAM_PROXY=socks5://127.0.0.1:1080
#   TELEGRAM_PROXY=http://user:pass@proxy-host:3128
TELEGRAM_PROXY=

# System admin account (auto-promoted to is_admin=True on startup)
ADMIN_USERNAME=
